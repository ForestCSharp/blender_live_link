 }
 
+PyDoc_STRVAR(
+    /* Wrap. */
+    bpy_app_live_link_compare_updates_doc,
+    ".. staticmethod:: live_link_compare_updates(native_bytes, python_bytes, max_diffs=100)\n"
+    "\n"
+    "   Compare native and Python Blender Live Link update bytes semantically.\n"
+    "\n"
+    "   :param native_bytes: Size-prefixed native Live Link update bytes.\n"
+    "   :type native_bytes: bytes\n"
+    "   :param python_bytes: Size-prefixed Python Live Link update bytes.\n"
+    "   :type python_bytes: bytes\n"
+    "   :param max_diffs: Maximum diagnostic differences to report.\n"
+    "   :type max_diffs: int\n"
+    "   :return: ``(matched, message)``.\n"
+    "   :rtype: tuple[bool, str]\n");
+static PyObject *bpy_app_live_link_compare_updates(PyObject * /*self*/,
+                                                  PyObject *args,
+                                                  PyObject *kwds)
+{
+  PyObject *native_bytes = nullptr;
+  PyObject *python_bytes = nullptr;
+  int max_diffs = 100;
+
+  static const char *_keywords[] = {"native_bytes", "python_bytes", "max_diffs", nullptr};
+  static _PyArg_Parser _parser = {
+      "OO|i" /* `native_bytes`, `python_bytes`, optional `max_diffs`. */
+      ":live_link_compare_updates",
+      _keywords,
+      nullptr,
+  };
+  if (!_PyArg_ParseTupleAndKeywordsFast(
+          args, kwds, &_parser, &native_bytes, &python_bytes, &max_diffs))
+  {
+    return nullptr;
+  }
+
+  return BPY_live_link_compare_updates(native_bytes, python_bytes, max_diffs);
+}
