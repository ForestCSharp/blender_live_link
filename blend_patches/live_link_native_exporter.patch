+PyDoc_STRVAR(
+    /* Wrap. */
+    bpy_app_live_link_make_update_doc,
+    ".. staticmethod:: live_link_make_update(objects, deleted_object_uids, dependency_graph, "
+    "reset=False, update_reason=\"unknown\", sequence=0)\n"
+    "\n"
+    "   Build a native Blender Live Link update.\n"
+    "\n"
+    "   :param objects: Blender objects considered for export.\n"
+    "   :type objects: sequence\n"
+    "   :param deleted_object_uids: Deleted object session UIDs.\n"
+    "   :type deleted_object_uids: sequence\n"
+    "   :param dependency_graph: Evaluated dependency graph to export against.\n"
+    "   :type dependency_graph: bpy.types.Depsgraph\n"
+    "   :param reset: Whether this update is a reset.\n"
+    "   :type reset: bool\n"
+    "   :param update_reason: Diagnostic reason for this update.\n"
+    "   :type update_reason: str\n"
+    "   :param sequence: Python-maintained update sequence number.\n"
+    "   :type sequence: int\n"
+    "   :return: Size-prefixed Live Link update bytes.\n"
+    "   :rtype: bytes\n");
+static PyObject *bpy_app_live_link_make_update(PyObject * /*self*/,
+                                               PyObject *args,
+                                               PyObject *kwds)
+{
+  PyObject *objects = nullptr;
+  PyObject *deleted_object_uids = nullptr;
+  PyObject *dependency_graph = nullptr;
+  bool reset = false;
+  const char *update_reason = "unknown";
+  int sequence = 0;
+
+  static const char *_keywords[] = {
+      "objects",
+      "deleted_object_uids",
+      "dependency_graph",
+      "reset",
+      "update_reason",
+      "sequence",
+      nullptr};
+  static _PyArg_Parser _parser = {
+      "OOO|O&si" /* `objects`, `deleted_object_uids`, `dependency_graph`, optional args. */
+      ":live_link_make_update",
+      _keywords,
+      nullptr,
+  };
+  if (!_PyArg_ParseTupleAndKeywordsFast(args,
+                                        kwds,
+                                        &_parser,
+                                        &objects,
+                                        &deleted_object_uids,
+                                        &dependency_graph,
+                                        PyC_ParseBool,
+                                        &reset,
+                                        &update_reason,
+                                        &sequence))
+  {
+    return nullptr;
+  }
+
+  return BPY_live_link_make_update(
+      objects, deleted_object_uids, dependency_graph, reset, update_reason, sequence);
+}
